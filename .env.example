# Public base URL of the Mahadev APF NestJS backend (server/).
# Baked into the static build; when set, contact/quote forms POST enquiries to
# `${NEXT_PUBLIC_API_URL}/api/leads` (CRM pipeline). The backend must allow the
# site's origin via CORS. Leave unset to run the marketing site standalone.
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Set automatically by the GitHub Pages workflow to the project subpath
# (e.g. "/mahadev-apf"). Leave unset for local development.
# PAGES_BASE_PATH=""
